generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  priceUsd    Float
  active      Boolean  @default(true)
  // Contenido a entregar tras el pago: texto, key, link, etc.
  deliveryContent String
  stock       Int?     // null = ilimitado (ej. keys generadas al vuelo)
  createdAt   DateTime @default(now())
  orders      Order[]
}

model Order {
  id            String      @id @default(cuid())
  product       Product     @relation(fields: [productId], references: [id])
  productId     String
  discordUserId String
  discordTag    String
  email         String
  status        OrderStatus @default(PENDING)
  priceUsd      Float
  payCurrency   String?     // ej. "btc", "usdttrc20"
  paymentId     String?     @unique // id de NOWPayments
  ticketChannelId String?
  createdAt     DateTime    @default(now())
  paidAt        DateTime?
  deliveredAt   DateTime?
}

enum OrderStatus {
  PENDING
  PAID
  DELIVERED
  EXPIRED
  FAILED
}
